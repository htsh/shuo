# Server
PORT=3040
DRAIN_TIMEOUT=300

# Twilio (Phone call mode only)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_PUBLIC_URL=https://your-public-url.example.com

# Speech-to-Text (Deepgram Flux)
DEEPGRAM_API_KEY=your_deepgram_api_key

# LLM / inference
# Live conversation path currently uses Groq-compatible chat completions.
GROQ_API_KEY=your_groq_api_key
LLM_MODEL=llama-3.3-70b-versatile
# Optional: used by /bench/ttft endpoint, not required for normal call flow.
OPENAI_API_KEY=your_openai_api_key

# Text-to-Speech (ElevenLabs)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Realtime browser/mobile sessions
# Use a long random secret in production.
REALTIME_SESSION_SECRET=replace_with_a_long_random_secret
REALTIME_TOKEN_TTL_SECONDS=60
REALTIME_ALLOWED_ORIGINS=http://localhost:3040,http://127.0.0.1:3040
REALTIME_MAX_SESSIONS_PER_IP=3
REALTIME_MAX_SESSION_MINTS_PER_MIN=30
